<Ui xmlns="http://www.blizzard.com/wow/ui/">
    <CheckButton name="MoneyLooterCheckButtonTemplate" virtual="true">
        <Size x="15" y="15" />
        <HitRectInsets>
            <AbsInset left="0" right="-100" top="0" bottom="0" />
        </HitRectInsets>
        <NormalTexture file="Interface\Buttons\UI-CheckBox-Up" />
        <PushedTexture file="Interface\Buttons\UI-CheckBox-Down" />
        <HighlightTexture file="Interface\Buttons\UI-CheckBox-Highlight" alphaMode="ADD" />
        <CheckedTexture file="Interface\Buttons\UI-CheckBox-Check" />
        <DisabledCheckedTexture file="Interface\Buttons\UI-CheckBox-Check-Disabled" />
    </CheckButton>

    <Frame name="MoneyLooterButtonBehaviorTemplate" mixin="MoneyLooterButtonBehaviorMixin"
        virtual="true">
        <Scripts>
            <OnEnter method="OnEnter" />
            <OnLeave method="OnLeave" />
        </Scripts>
    </Frame>

    <Button name="MoneyLooterMenuButtonTemplate" inherits="MoneyLooterButtonBehaviorTemplate"
        virtual="true">
        <Size x="132" y="20" />
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="NormalTexture" atlas="auctionhouse-nav-button"
                    useAtlasSize="false">
                    <Size x="136" y="32" />
                    <Anchors>
                        <Anchor point="TOPLEFT" x="-2" y="0" />
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="BORDER">
                <Texture parentKey="HighlightTexture" atlas="auctionhouse-nav-button-highlight"
                    hidden="true">
                    <Anchors>
                        <Anchor point="CENTER" />
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <Texture parentKey="MouseoverOverlay" hidden="true" atlas="auctionhouse-nav-button"
                    useAtlasSize="false" alphaMode="ADD" />
                <FontString parentKey="Label" inherits="GameFontHighlight">
                    <Size x="180" y="16" />
                    <Anchors>
                        <Anchor point="CENTER" />
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Button>

    <Button name="MoneyLooterScrollBoxButtonTemplate" inherits="MoneyLooterButtonBehaviorTemplate"
        mixin="MoneyLooterScrollBoxButtonMixin" virtual="true">
        <Size y="20" />
        <Layers>
            <Layer level="BACKGROUND">
                <Texture>
                    <Color r=".1" g=".1" b=".1" a="1" />
                </Texture>
                <Texture parentKey="Alternate" hidden="true" alphaMode="ADD">
                    <Color r=".02" g=".02" b=".02" a="1" />
                </Texture>
                <Texture parentKey="MouseoverOverlay" hidden="true" alphaMode="ADD">
                    <Color r=".1" g=".1" b=".1" a="1" />
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <Texture parentKey="FlashOverlay">
                    <Color r="1" b="1" g="1" a=".5" />
                    <Animations>
                        <AnimationGroup parentKey="Anim" setToFinalAlpha="true"
                            inherits="VisibleWhilePlayingAnimGroupTemplate">
                            <Alpha fromAlpha="0.5" toAlpha="1" duration="0.5" order="1"
                                smoothing="IN" />
                            <Alpha fromAlpha="1" toAlpha="0.0" duration="0.5" order="2"
                                smoothing="IN" />
                        </AnimationGroup>
                    </Animations>
                </Texture>
            </Layer>
        </Layers>
    </Button>

    <Button name="MoneyLooterLogItemButtonTemplate" inherits="MoneyLooterScrollBoxButtonTemplate"
        registerForClicks="AnyUp" mixin="MoneyLooterLogItemButtonMixin" virtual="true">
        <Size y="20" />
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="RightLabel" inherits="GameFontHighlightSmall" justifyH="RIGHT">
                    <Size y="20" />
                    <Anchors>
                        <Anchor point="RIGHT" x="-5" />
                    </Anchors>
                </FontString>
                <FontString parentKey="LeftLabel" inherits="GameFontHighlightSmall" wordwrap="false" justifyH="LEFT">
                    <Size y="20" />
                    <Anchors>
                        <Anchor point="LEFT" x="5" />
                        <Anchor point="RIGHT" relativeKey="$parent.RightLabel" relativePoint="LEFT"
                            x="-5" />
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnEnter method="OnEnter" />
            <OnLeave method="OnLeave" />
        </Scripts>
    </Button>

    <Button name="MoneyLooterLogMessageButtonTemplate" inherits="MoneyLooterScrollBoxButtonTemplate" mixin="MoneyLooterLogMessageButtonMixin" virtual="true">
		<Size x="100" y="20"/>
		<Layers>
			<Layer level="OVERLAY">
				<FontString parentKey="RightLabel" inherits="GameFontHighlightSmall" justifyH="RIGHT">
					<Size y="20"/>
					<Anchors>
						<Anchor point="RIGHT" x="-5"/>
					</Anchors>
				</FontString>
				<FontString parentKey="LeftLabel" inherits="GameFontHighlightSmall" wordwrap="false" justifyH="LEFT">
					<Size y="20"/>
					<Anchors>
						<Anchor point="LEFT" x="5"/>
						<Anchor point="RIGHT" relativeKey="$parent.RightLabel" relativePoint="LEFT" x="-5"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnEnter method="OnEnter"/>
			<OnLeave method="OnLeave"/>
		</Scripts>
	</Button>
    
    <Frame name="MoneyLooter" mixin="MoneyLooterPanelMixin" inherits="ButtonFrameTemplate"
        parent="UIParent" toplevel="true" movable="true" resizable="true" enableMouse="true"
        frameStrata="DIALOG">
        <Size x="600" y="400" />
        <Anchors>
            <Anchor point="CENTER" />
        </Anchors>
        <Frames>
            <Frame parentKey="TitleBar" inherits="PanelDragBarTemplate">
                <Size y="32" />
                <Anchors>
                    <Anchor point="TOPLEFT" />
                    <Anchor point="TOPRIGHT" />
                </Anchors>
                <Layers></Layers>
            </Frame>
            <Button parentKey="ResizeButton" inherits="PanelResizeButtonTemplate">
                <Anchors>
                    <Anchor point="BOTTOMRIGHT" x="-4" y="4" />
                </Anchors>
            </Button>
            <Frame parentKey="SubtitleBar">
                <Size y="32" />
                <Anchors>
                    <Anchor point="TOPLEFT" />
                    <Anchor point="TOPRIGHT" />
                </Anchors>
                <Frames>
                    <Button parentKey="MoneyLooterStart" inherits="MoneyLooterMenuButtonTemplate">
                        <Anchors>
                            <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" x="5" />
                        </Anchors>
                    </Button>
                    <Button parentKey="MoneyLooterReset" inherits="MoneyLooterMenuButtonTemplate">
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeKey="$parent.MoneyLooterStart"
                                relativePoint="TOPRIGHT" x="5" />
                        </Anchors>
                    </Button>
                    <DropdownButton parentKey="OptionsDropdown"
                        inherits="WowStyle1FilterDropdownTemplate">
                        <Anchors>
                            <Anchor point="TOPRIGHT" relativePoint="BOTTOMRIGHT" x="-20" />
                        </Anchors>
                    </DropdownButton>
                </Frames>
            </Frame>

            <Frame parentKey="Log">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.SubtitleBar"
                        relativePoint="BOTTOMLEFT" x="8" y="-32" />
                    <Anchor point="BOTTOMRIGHT" x="-9" y="28" />
                </Anchors>
                <Frames>
                    <Frame parentKey="Bar">
                        <Size y="24" />
                        <Anchors>
                            <Anchor point="TOPLEFT" />
                            <Anchor point="TOPRIGHT" />
                        </Anchors>
                        <Layers>
                            <Layer level="OVERLAY">
                                <FontString parentKey="Label" inherits="GameFontHighlight"
                                    justifyH="LEFT">
                                    <Size x="135" y="10" />
                                    <Anchors>
                                        <Anchor point="LEFT" x="12" y="0" />
                                    </Anchors>
                                </FontString>
                            </Layer>
                        </Layers>
                        <Frames>
                            <Button parentKey="MoneyLooterInstance"
                                inherits="MoneyLooterMenuButtonTemplate">
                                <Anchors>
                                    <Anchor point="RIGHT" x="-3" y="0" />
                                </Anchors>
                            </Button>
                            <!-- <Button parentKey="MoneyLooterStartButton"
                                inherits="MoneyLooterMenuButtonTemplate">
                                <Anchors>
                                    <Anchor point="RIGHT"
                                        relativeKey="$parent.MoneyLooterResetButton"
                                        relativePoint="LEFT" x="-3" />
                                </Anchors>
                            </Button> -->
                        </Frames>
                    </Frame>
                    <Frame parentKey="LootedItems">
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeKey="$parent.Bar"
                                relativePoint="BOTTOMLEFT" y="-2" />
                            <Anchor point="BOTTOMRIGHT" />
                        </Anchors>
                        <Frames>
                            <Frame parentKey="ScrollBox" inherits="WowScrollBoxList">
                                <Anchors>
                                    <Anchor point="TOPLEFT" />
                                    <Anchor point="BOTTOMRIGHT" x="-25" />
                                </Anchors>
                                <Layers>
                                    <Layer level="BACKGROUND">
                                        <Texture>
                                            <Color r=".03" g=".03" b=".03" a="1" />
                                        </Texture>
                                    </Layer>
                                </Layers>
                            </Frame>
                            <EventFrame parentKey="ScrollBar" inherits="MinimalScrollBar">
                                <Anchors>
                                    <Anchor point="TOPLEFT" relativeKey="$parent.ScrollBox"
                                        relativePoint="TOPRIGHT" x="5" y="-8" />
                                    <Anchor point="BOTTOMLEFT" relativeKey="$parent.ScrollBox"
                                        relativePoint="BOTTOMRIGHT" x="5" y="5" />
                                </Anchors>
                            </EventFrame>
                        </Frames>
                    </Frame>
                </Frames>
            </Frame>
        </Frames>
        <Scripts>
            <OnLoad method="OnLoad" />
            <OnEvent method="OnEvent" />
            <OnShow method="OnShow" />
            <OnHide method="OnHide" />
        </Scripts>
    </Frame>
    <!-- <GameTooltip name="MoneyLooterTooltip" frameStrata="TOOLTIP" hidden="true" parent="MoneyLooter"
        inherits="SharedTooltipTemplate" /> -->
</Ui>